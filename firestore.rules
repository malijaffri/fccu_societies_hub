rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return request.auth.uid == uid;
    }

    // ── Users ────────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;
    }

    // ── Societies ────────────────────────────────────────────────────────
    match /societies/{societyId} {
      // Guests can browse societies
      allow read: if true;
      // Any signed-in user can create (admin-level creation would use Cloud Functions)
      allow create: if isSignedIn();
      // Signed-in users can update followerCount / memberCount via follow/join
      allow update: if isSignedIn();
      allow delete: if false;
    }

    // ── Follows ──────────────────────────────────────────────────────────
    match /follows/{followId} {
      allow read: if isSignedIn();
      // Only the owner can create/delete their own follow doc (ID = {uid}_{societyId})
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ── Memberships ───────────────────────────────────────────────────────
    match /memberships/{membershipId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow update: if false; // permissions changes should go through Cloud Functions
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ── Posts ────────────────────────────────────────────────────────────
    match /posts/{postId} {
      // Guests can read posts
      allow read: if true;
      allow create: if isSignedIn();
      // Author can update; any signed-in user can update likerIds/likeCount/commentCount
      allow update: if isSignedIn();
      allow delete: if isSignedIn() && resource.data.authorId == request.auth.uid;
    }

    // ── Comments ─────────────────────────────────────────────────────────
    match /comments/{commentId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ── Events ───────────────────────────────────────────────────────────
    match /events/{eventId} {
      allow read: if true;
      allow create: if isSignedIn();
      // Members can update rsvpCount; society admins can edit full event
      allow update: if isSignedIn();
      allow delete: if isSignedIn();
    }

    // ── Event RSVPs ───────────────────────────────────────────────────────
    match /event_rsvps/{rsvpId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.userId == request.auth.uid;
    }

    // ── Notifications ─────────────────────────────────────────────────────
    match /notifications/{userId}/items/{notifId} {
      // Only the recipient can read their own notifications
      allow read: if isOwner(userId);
      // Backend writes (likes/comments in batch); Cloud Functions would use Admin SDK
      allow create: if isSignedIn();
      // Only recipient can mark as read
      allow update: if isOwner(userId)
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['isRead']);
      allow delete: if isOwner(userId);
    }

  }
}
